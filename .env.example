DJANGO_SECRET_KEY=change-this-to-a-long-random-secret
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost,your-domain.example.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://your-domain.example.com
DJANGO_ADMIN_USERNAME=admin
DJANGO_ADMIN_PASSWORD=change-this-to-a-strong-password
DATABASE_URL=postgresql://windprofiler:password@database:5432/windprofiler
DJANGO_SECURE_SSL_REDIRECT=True
DJANGO_SECURE_HSTS_SECONDS=31536000
